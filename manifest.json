{
  "manifest_version": 3,
  "name": "Activity Tracker",
  "version": "2.0",
  "description": "Rastreia tempo em Slack, Google Agenda, Sheets e Databricks",
  "permissions": ["tabs", "storage", "alarms", "identity"],
  "oauth2": {
    "client_id": "598357292473-anuq7polohu72eh4s45lnu689g4e4vgv.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.readonly"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Activity Tracker"
  }
}
